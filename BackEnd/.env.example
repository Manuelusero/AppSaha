# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# ── Node Environment ──
NODE_ENV=development

# ── Database (PostgreSQL via Prisma) ──
# Development: Use local PostgreSQL or Neon
# Production: Use Neon or Azure Database for PostgreSQL
DATABASE_URL="postgresql://username:password@host:5432/database_name?sslmode=require"

# Example for Neon (free tier):
# DATABASE_URL="postgresql://user:password@ep-xxx-xxx-xxx.region.neon.tech/database?sslmode=require"

# Example for Azure PostgreSQL:
# DATABASE_URL="postgresql://username@servername:password@servername.postgres.database.azure.com:5432/dbname?sslmode=require"

# ── JWT Authentication ──
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ── Cloudinary (File Uploads) ──
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── CORS Configuration ──
# Frontend URL for CORS (production)
FRONTEND_URL="https://your-app.vercel.app"

# ── Server Configuration ──
PORT=8000

# ── Prisma (Optional) ──
# Uncomment if you want to use Prisma Accelerate or Prisma Data Proxy
# PRISMA_ACCELERATE_URL="your-accelerate-url"

# ============================================
# DEPLOYMENT NOTES
# ============================================

# Vercel:
# - Add all environment variables in Vercel Dashboard → Settings → Environment Variables
# - DATABASE_URL, JWT_SECRET, CLOUDINARY_* are REQUIRED
# - FRONTEND_URL should be your Vercel frontend URL

# Azure Database for PostgreSQL:
# - Connection string format: postgresql://username@servername:password@servername.postgres.database.azure.com:5432/dbname?sslmode=require
# - Configure firewall rules to allow your IP or Azure services
# - Enable SSL connections (required)

# Security:
# - Never commit .env file to Git
# - Use different secrets for development and production
# - Rotate JWT_SECRET periodically
# - Keep Cloudinary credentials secure
