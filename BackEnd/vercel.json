{
    "version": 2,
    "builds": [
        {
            "src": "api/index.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.ts"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/remind-incomplete",
            "schedule": "0 10 * * *"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    }
}